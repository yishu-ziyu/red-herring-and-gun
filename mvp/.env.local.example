STEPFUN_API_KEY=
STEPFUN_BASE_URL=https://api.stepfun.com/v1
STEPFUN_MODEL=step-2-mini

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
# OPENAI_BASE_URL=https://api.openai.com/v1

# Optional fallback providers
MIMO_API_KEY=
MIMO_BASE_URL=https://token-plan-cn.xiaomimimo.com/anthropic
MIMO_MODEL=mimo-v2.5-pro
# Optional: Moonshot / Kimi (currently no key configured in this project)
# KIMI_API_KEY=
# MOONSHOT_BASE_URL=https://api.moonshot.cn/v1
# KIMI_MODEL=kimi-latest
ORCHESTRATE_TEXT_PROVIDER_ORDER=deepseek,mimo,stepfun,360,anthropic
ORCHESTRATE_PROVIDER_TIMEOUT_MS=60000
ORCHESTRATE_PROVIDER_MAX_TOKENS=2400

DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-v4-pro
# Optional per-agent override. The final report is stricter JSON synthesis, so a non-reasoning chat model can be more stable.
DEEPSEEK_REPORT_COMPOSER_MODEL=deepseek-v4-pro

# 360 AI Search (server-side; fill one key when deploying)
QIHOO_360_API_KEY=
# ZHINAO_API_KEY=
# AI360_API_KEY=
AI360_BASE_URL=https://api.360.cn/v1
AI360_CHAT_MODEL=360gpt-pro
SEARCH360_MODEL=360gpt-pro
SEARCH360_REF_PROM=aiso-pro

# If remote provider keys are omitted, the local dev proxy falls back to Codex CLI.
# It first tries the active Anthropic-compatible local proxy from ~/.claude/settings.json.
# ANTHROPIC_BASE_URL=http://127.0.0.1:18765
# ANTHROPIC_MODEL=gpt-5.5
# ANTHROPIC_AUTH_TOKEN=your-local-token
# CODEX_BIN=/Users/mahaoxuan/.local/bin/codex
# CODEX_LOCAL_MODEL=gpt-5.5
# CODEX_LOCAL_TIMEOUT_MS=180000
