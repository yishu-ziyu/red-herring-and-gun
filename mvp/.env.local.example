OPENAI_API_KEY=sk-your-key
OPENAI_MODEL=gpt-4.1-mini
# OPENAI_BASE_URL=https://api.openai.com/v1

# If OPENAI_API_KEY is omitted, the local dev proxy falls back to Codex CLI.
