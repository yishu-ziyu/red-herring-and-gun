STEPFUN_API_KEY=
STEPFUN_BASE_URL=https://api.stepfun.com/v1
STEPFUN_MODEL=step-2-mini
# StepFun 3.7 Flash is a slower reasoning model. Keep reasoning short and give it its own timeout.
STEPFUN_3_7_REASONING_EFFORT=low
STEPFUN_3_7_PROVIDER_TIMEOUT_MS=135000
STEPFUN_3_7_MIN_MAX_TOKENS=4096

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
# OPENAI_BASE_URL=https://api.openai.com/v1

# Optional fallback providers
MINIMAX_API_KEY=
# Optional legacy/token-plan alias. Either MINIMAX_API_KEY or MINIMAX_TOKEN_PLAN_KEY enables MiniMax.
MINIMAX_TOKEN_PLAN_KEY=
MINIMAX_BASE_URL=https://api.minimaxi.com/anthropic
MINIMAX_MODEL=MiniMax-M3
# Default follows local AI组件工作流 MiniMax Anthropic-compatible examples. Set to bearer only for Bearer-auth keys.
MINIMAX_AUTH_HEADER=x-api-key
MIMO_API_KEY=
MIMO_BASE_URL=https://token-plan-cn.xiaomimimo.com/anthropic
MIMO_MODEL=mimo-v2.5-pro
# Optional: Moonshot / Kimi (currently no key configured in this project)
# KIMI_API_KEY=
# MOONSHOT_BASE_URL=https://api.moonshot.cn/v1
# KIMI_MODEL=kimi-latest
ORCHESTRATE_TEXT_PROVIDER_ORDER=stepfun,360,deepseek,mimo,minimax,anthropic
ORCHESTRATE_REPORT_COMPOSER_PROVIDER_ORDER=360,stepfun,deepseek,mimo,minimax,anthropic
ORCHESTRATE_PROVIDER_TIMEOUT_MS=25000
ORCHESTRATE_PROVIDER_MAX_TOKENS=2400

DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-v4-pro
# Optional per-agent override. The final report is stricter JSON synthesis, so a non-reasoning chat model can be more stable.
DEEPSEEK_REPORT_COMPOSER_MODEL=deepseek-v4-pro

# 360 AI Search (server-side; fill one key when deploying)
QIHOO_360_API_KEY=
# ZHINAO_API_KEY=
# AI360_API_KEY=
AI360_BASE_URL=https://api.360.cn/v1
AI360_CHAT_MODEL=360gpt-pro
SEARCH360_MODEL=360gpt-pro
SEARCH360_REF_PROM=aiso-pro

# AI Ping OAuth2 account integration
PUBLIC_BASE_URL=https://gun.yishuziyu.cn
AIPING_CLIENT_ID=
AIPING_CLIENT_SECRET=
AIPING_SESSION_SECRET=
AIPING_REDIRECT_URI=https://gun.yishuziyu.cn/api/auth/aiping/callback
AIPING_AUTH_BASE_URL=https://central.qc-ai.cn
AIPING_SCOPE=profile phone

# If remote provider keys are omitted, the local dev proxy falls back to Codex CLI.
# It first tries the active Anthropic-compatible local proxy from ~/.claude/settings.json.
# ANTHROPIC_BASE_URL=http://127.0.0.1:18765
# ANTHROPIC_MODEL=gpt-5.5
# ANTHROPIC_AUTH_TOKEN=your-local-token
# CODEX_BIN=/Users/mahaoxuan/.local/bin/codex
# CODEX_LOCAL_MODEL=gpt-5.5
# CODEX_LOCAL_TIMEOUT_MS=180000
