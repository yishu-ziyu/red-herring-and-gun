# ANTHROPIC_MODEL=gpt-5.5[1m]
# ANTHROPIC_AUTH_TOKEN=your-local-token
# CODEX_BIN=/Users/mahaoxuan/.local/bin/codex
# CODEX_LOCAL_MODEL=gpt-5.5
# CODEX_LOCAL_TIMEOUT_MS=180000
