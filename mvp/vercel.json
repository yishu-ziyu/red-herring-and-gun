{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "rewrites": [
    {
      "source": "/health",
      "destination": "/health.json"
    },
    {
      "source": "/api/:path*",
      "destination": "http://121.89.90.68/api/:path*"
    },
    {
      "source": "/((?!api/|.*\\..+$).*)",
      "destination": "/index.html"
    }
  ]
}
